{
  "mcpServers": {
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ]
    },
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/eliahkadu/Desktop/_follower_"
      ]
    },
    "neo4j": {
      "type": "stdio",
      "command": "/Users/eliahkadu/Desktop/_follower_/mcp/with-env.sh",
      "args": [
        "uvx",
        "mcp-neo4j-cypher",
        "--transport",
        "stdio"
      ]
    },
    "qdrant": {
      "type": "stdio",
      "command": "python3",
      "args": [
        "/Users/eliahkadu/Desktop/_follower_/mcp/ollama_qdrant_server.py"
      ],
      "env": {
        "COLLECTION_NAME": "workflow_memory",
        "QDRANT_URL": "http://localhost:6333",
        "EMBEDDING_PROVIDER": "ollama",
        "OLLAMA_URL": "http://localhost:11434",
        "OLLAMA_MODEL": "bge-m3"
      }
    },
    "github": {
      "type": "stdio",
      "command": "/Users/eliahkadu/Desktop/_follower_/mcp/with-env.sh",
      "args": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ]
    },
    "semgrep": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--python",
        "3.13",
        "semgrep-mcp"
      ]
    }
  }
}