# === Ports (auto-detected by setup.sh — leave blank for auto) ===
QDRANT_PORT=
QDRANT_GRPC_PORT=
NEO4J_HTTP_PORT=
NEO4J_BOLT_PORT=

# === Infrastructure (auto-configured by setup.sh) ===
QDRANT_URL=
NEO4J_URI=
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=workflow
NEO4J_DATABASE=neo4j

# === MCP Servers ===
COLLECTION_NAME=workflow_memory
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
GITHUB_PERSONAL_ACCESS_TOKEN=

# === Ollama (default embedding provider — bge-m3 1024d) ===
# Start: docker compose up -d ollama (in infra/)
# Fallback: set EMBEDDING_PROVIDER=fastembed to use local fastembed (384d, no external service)
EMBEDDING_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_PORT=11434
